---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Separator from "../../components/Separator.astro";

const mediaImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/media/**/*.{jpg,jpeg,png,webp,avif,gif}'
);


export const getStaticPaths = async () => {
  // Fetch all updates
  const updatesCollection = await getCollection("updates");

  // Map over the updates to generate paths for each update's page
  const paths = updatesCollection.map((update) => {
    return {
      params: { update_id: update.id }, 
      props: { updatesCollection, update }, 
    };
  });

  // Return the generated paths to Astro for  page generation
  return paths;
};


type Props = {
  updatesCollection: CollectionEntry<"updates">[]; // Array of all updates in the collection
  update: CollectionEntry<"updates">; // Current update being rendered
};

const { updatesCollection, update } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Resolve a frontmatter path like "../../assets/media/foo.jpg" to ImageMetadata
const resolveImage = async (path: string): Promise<ImageMetadata | null> => {
  const filename = path.split('/').pop();
  const key = `/src/assets/media/${filename}`;
  const loader = mediaImages[key];
  if (!loader) return null;
  const mod = await loader();
  return mod.default;
};

// Extract the ID of the current update
const update_id = update.id;

// Find the index of the current update in the updates array
const currentUpdateIndex = updatesCollection.findIndex((a) => a.id === update_id);


// Render the content of the current update (e.g., markdown or MDX)
const { Content } = await render(update);
---

<BaseLayout title={update.data.title}>
  <section>
    <header class="title-header">
      <h2>
        {update.data.title}
      </h2>
      <span class="faded">({update.data.pubDate})</span>
    </header>
    <Separator />
    <div class="content-wrap">
        <Content />
    </div>
  </section>
</BaseLayout>
<style>
  

</style>
