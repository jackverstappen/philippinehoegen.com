---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Separator from "../../components/Separator.astro";
import Gallery from "../../components/Gallery.astro";
import Prose from '../../components/Prose.astro';

const mediaImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/works/**/*.{jpg,jpeg,png,webp,avif,gif}'
);


export const getStaticPaths = async () => {
  // Fetch all works from the 'works' collection
  const workCollection = await getCollection("works");

  // Map over the works to generate paths for each work's page
  const paths = workCollection.map((work) => {
    return {
      params: { work_id: work.id }, // URL parameter for the work's ID
      props: { workCollection, work }, // Pass the full work and all works as props
    };
  });

  // Return the generated paths to Astro for  page generation
  return paths;
};


type Props = {
  workCollection: CollectionEntry<"works">[]; // Array of all works in the collection
  work: CollectionEntry<"works">; // Current work being rendered
};

const { workCollection, work } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Resolve a frontmatter path like "./slug/cover.jpg" to ImageMetadata
const resolveImage = async (path: string): Promise<ImageMetadata | null> => {
  const key = `/src/content/works/${path.replace(/^\.\//, '')}`;
  const loader = mediaImages[key];
  if (!loader) return null;
  const mod = await loader();
  return mod.default;
};

// Extract the ID of the current work
const work_id = work.id;

// Find the index of the current work in the works array
const currentWorkIndex = workCollection.findIndex((a) => a.id === work_id);

// Calculate the index of the "next" work in the array (wrap around if at the last work)
const prevWorkIndex = (workCollection.length+currentWorkIndex - 1) % workCollection.length;
const nextWorkIndex = (workCollection.length+currentWorkIndex + 1) % workCollection.length;

// Get the "next" work based on the calculated index
const prevWork = workCollection[prevWorkIndex];
const nextWork = workCollection[nextWorkIndex];
const mediaCount = work.data.media ? work.data.media.length : 0;

const coverImage = work.data.cover ? await resolveImage(work.data.cover) : null;

const slides = (!work.data.media || !work.data.media.length) ? [] :
  (await Promise.all(
    work.data.media.map(async (m) => {
      const img = await resolveImage(m);
      return img ? { src: img, alt: work.data.title, caption: undefined } : null;
    })
  )).filter(Boolean);

// Render the content of the current work (e.g., markdown or MDX)
const { Content } = await render(work);
---

<BaseLayout title={work.data.title}>
  <section>
    <header class="title-header">
      <h2>
        {work.data.title}
      </h2>
      <p><span class="meta faded">&lbrack; DESC &rbrack;: </span><span>{work.data.desc})</span></p>
      <p><span class="meta faded">&lbrack; KEYWORDS &rbrack;: </span><span>{work.data.keywords}</span></p>
      <p><span class="meta faded">&lbrack; TAGS &rbrack;: </span><span>
        {work.data.tags ? work.data.tags.join(" | ").toUpperCase() : ""
        }</span></p>
        
      <div class="mt-2">
        <a href={`${base}/works/${prevWork.id}`}>Prev</a>
        <span class="faded">|</span>
        <a href={`${base}/works`}>View all</a>
        <span class="faded">|</span>
        <a href={`${base}/works/${nextWork.id}`}>Next</a>
      </div>
    </header>
    <Separator />
    <div class="content-wrap">
      <div>
        {coverImage && (
          <Image
            class="image fade-in cover"
            src={coverImage}
            alt={work.data.title}
          />
        )}
        <span>{mediaCount} media-files associated</span>
        <Gallery
      images={slides}
      label={work.data.title}
      columns={3}
    />
      </div>
      <div class="content">
        <Prose>
        <Content />
        </Prose>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
  span {
    font-weight: 400;
  }
  .meta {
    font-size:.75rem;
    font-weight: 700;
    text-align: right;
    width: 5rem;
    min-width:5rem;
    color:goldenrod;
  }
    ul li:first-child {
        margin-left: 20px;
    }
    ul li { 
        font-weight:700;
        margin-inline:4px; list-style: none; display: inline; }

   p {
    margin-block: 0rem;
  }


  .content-wrap {
    grid-template-areas: "content" "img" "works";
    grid-template-columns: 100%;

    /* On mobile, text first — image second */
    & > :first-child { order: 2; }
    & > .content    { order: 1; }

    @media screen and (min-width: 44em) {
      grid-template-columns: 1fr auto;
      grid-template-areas: "img img" "content works";
      & > :first-child { order: unset; }
      & > .content    { order: unset; }
    }

    @media screen and (min-width: 50em) {
      grid-template-columns: 30vw 1fr 170px;
      grid-template-areas: "img content works";
    }
  }
  .albums {
    grid-area: works;
  }
  .content p:last-child {
    margin-top: 2.5rem;
    display: flex;
  }
  .cover {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
  display: block;
}

</style>

<script define:vars={{ prevUrl: `${base}/works/${prevWork.id}`, nextUrl: `${base}/works/${nextWork.id}`, viewAllUrl: `${base}/works` }}>
  const isGalleryOpen = () =>
    !document.querySelector('[data-gallery-backdrop]')?.hasAttribute('hidden');

  window.addEventListener('keydown', (e) => {
    if (isGalleryOpen()) return;

    if (e.key === 'ArrowLeft')   { window.location.href = prevUrl; }
    if (e.key === 'Backspace')   { window.location.href = viewAllUrl; }
    if (e.key === 'ArrowRight') { window.location.href = nextUrl; }

    if (e.key === ' ') {
      e.preventDefault();
      document.querySelector('[data-gallery-thumb]')?.click();
    }
  }, { capture: true });
</script>
