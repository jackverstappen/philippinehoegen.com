---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = await getCollection('bio');
const entry = entries[0];

if (!entry) {
  return Astro.redirect('/');
}

const { Content } = await render(entry);
---

<BaseLayout title="Bio">
  <section class="bio-page">
    <Content />
  </section>
</BaseLayout>

<style>
  .bio-page {
    max-width: 72ch;
    margin-inline: auto;
    padding-block: 2rem;
  }

  .bio-page :global(details) {
    border-top: 1px solid var(--color-border, currentColor);
    padding-block: 0.5rem;
  }

  .bio-page :global(details + details) {
    border-top: none;
  }

  .bio-page :global(summary) {
    cursor: pointer;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding-block: 0.5rem;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    user-select: none;
  }

  .bio-page :global(summary::-webkit-details-marker) {
    display: none;
  }

  .bio-page :global(summary::before) {
    content: '+';
    font-size: 1rem;
    line-height: 1;
    transition: transform 0.15s ease;
  }

  .bio-page :global(details[open] > summary::before) {
    content: '–';
  }

  .bio-page :global(details > *:not(summary)) {
    padding-inline-start: 1.25rem;
  }

  .bio-page :global(h2) {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-block-end: 0.25rem;
  }

  .bio-page :global(h3) {
    font-size: 0.6875rem;
    font-weight: 700;
    margin-block: 0.75rem 0.25rem;
  }

  .bio-page :global(h4) {
    font-size: 0.6875rem;
    font-weight: 700;
    margin-block: 0.75rem 0.25rem;
  }

  .bio-page :global(ul) {
    padding-inline-start: 1rem;
    margin-block: 0.25rem;
  }

  .bio-page :global(li) {
    font-size: 0.6875rem;
    margin-block: 0.125rem;
  }

  .bio-page :global(p) {
    font-size: 0.6875rem;
    margin-block: 0.5rem;
  }

  .bio-page :global(a) {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .bio-page :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border, currentColor);
    margin-block: 0.5rem;
  }

  /* Contact section */
  .bio-page :global(h3:last-of-type) {
    margin-block-start: 1.5rem;
  }
</style>
