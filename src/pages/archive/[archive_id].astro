---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Separator from "../../components/Separator.astro";
import Gallery from "../../components/Gallery.astro";

const mediaImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/archive/**/*.{jpg,jpeg,png,webp,avif,gif}'
);


export const getStaticPaths = async () => {
  const archiveCollection = await getCollection("archive");

  const paths = archiveCollection.map((archive) => {
    return {
      params: { archive_id: archive.id }, 
      props: { archiveCollection, archive }, 
    };
  });

  // Return the generated paths to Astro for  page generation
  return paths;
};


type Props = {
  archiveCollection: CollectionEntry<"archive">[]; 
  archive: CollectionEntry<"archive">; 
};

const { archiveCollection, archive } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Resolve a frontmatter path like "./uuid.jpg" to ImageMetadata
const resolveImage = async (path: string): Promise<ImageMetadata | null> => {

  console.log('resolveImage',path);

  const filename = path.replace(/^\.\//, '');
  const key = `/src/content/archive/${archive.id}/${filename}`;
  const loader = mediaImages[key];
  if (!loader) return null;
  const mod = await loader();
  return mod.default;
};

const archive_id = archive.id;

const currentWorkIndex = archiveCollection.findIndex((a) => a.id === archive_id);

const prevWorkIndex = (archiveCollection.length+currentWorkIndex - 1) % archiveCollection.length;
const nextWorkIndex = (archiveCollection.length+currentWorkIndex + 1) % archiveCollection.length;
const prevWork = archiveCollection[prevWorkIndex];
const nextWork = archiveCollection[nextWorkIndex];
const mediaCount = archive.data.media ? archive.data.media.length : 0;

const coverImage = archive.data.cover ? await resolveImage(archive.data.cover) : null;

const slides = (!archive.data.media || !archive.data.media.length) ? [] :
  (await Promise.all(
    archive.data.media.map(async (m) => {
      const img = await resolveImage(m);
      return img ? { src: img, alt: archive.data.title, caption: undefined } : null;
    })
  )).filter(Boolean);

const { Content } = await render(archive);
---

<BaseLayout title={archive.data.title}>
  <section>
    <header class="title-header">
      <h2>
        {archive.data.title}
      </h2>
      <span class="faded">({archive.data.title})</span>
      <div>
        <a href={`${base}/archive/${prevWork.id}`}>Prev</a>
        <span class="faded">|</span>
        <a href={`${base}/archive`}>View all</a>
        <span class="faded">|</span>
        <a href={`${base}/archive/${nextWork.id}`}>Next</a>
      </div>
    </header>
    <Separator />
    <div class="content-wrap">
      <div>
        {coverImage && (
          <Image
            class="image fade-in cover"
            src={coverImage}
            alt={archive.data.title}
          />
        )}
        <span>{mediaCount} media-files associated</span>
        <Gallery
      images={slides}
      label={archive.data.title}
      columns={3}
    />
      </div>
      <div class="content">
        <div class="tags">
        <ul class="tag-list">
          {(archive.data.tags ? archive.data.tags :[]).map((tag) => <li class="tag-item">{tag}</li>)}

        </ul>
        </div>
        <h3>{archive.data.title}</h3>
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>
<style>
    ul:before {
            content: "TAGS: ";
    }
    ul {
    font-size: .6875rem;
        font-weight:700;
        padding-inline-start: 0px;
    }
    ul li:first-child {
        margin-left: 20px;
    }
    ul li { 
        font-weight:700;
        margin-inline:4px; list-style: none; display: inline; }


  .content-wrap {
    grid-template-areas: "img" "content" "archive";
    grid-template-columns: 100%;

    @media screen and (min-width: 44em) {
      grid-template-columns: 1fr auto;
      grid-template-areas: "img img" "content archive";
    }
    
    @media screen and (min-width: 50em) {
      grid-template-columns: 30vw 1fr 170px;
      grid-template-areas: "img content archive";
    }
  }
  .content p:last-child {
    margin-top: 2.5rem;
    display: flex;
  }
  .cover {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
  display: block;
}

</style>

<script define:vars={{ prevUrl: `${base}/archive/${prevWork.id}`, nextUrl: `${base}/archive/${nextWork.id}` }}>
  const isGalleryOpen = () =>
    !document.querySelector('[data-gallery-backdrop]')?.hasAttribute('hidden');

  window.addEventListener('keydown', (e) => {
    if (isGalleryOpen()) return;

    if (e.key === 'ArrowLeft')   { window.location.href = prevUrl; }
    if (e.key === 'ArrowRight') { window.location.href = nextUrl; }

    if (e.key === ' ') {
      e.preventDefault();
      document.querySelector('[data-gallery-thumb]')?.click();
    }
  }, { capture: true });
</script>
