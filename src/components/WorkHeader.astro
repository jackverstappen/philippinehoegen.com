---
type Props = {
  tags: string[];
};

const { tags } = Astro.props;
---

<header class="title-header">
  <h2>Works</h2>

  <div class="flex items-center justify-between gap-4 mt-2">
    <span id="header-caption" class="text-base text-muted"></span>

    <div class="flex items-baseline gap-2 w-[360px] shrink-0">
      <input
        type="search"
        id="search-input"
        placeholder="Search"
        aria-label="Filter works by title"
        autocomplete="off"
        class="text-base flex-1 min-w-0"
      />

      {tags.length > 0 && (
        <div class="relative">
          <button
            type="button"
            id="tag-trigger"
            class="flex items-center gap-1.5 whitespace-nowrap"
            aria-haspopup="listbox"
            aria-expanded="false"
          >
            Tags
            <span
              id="tag-badge"
              class="bg-ink text-surface text-sm font-medium rounded-full px-1.5 py-px min-w-[18px] text-center"
              hidden
            ></span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div
            id="tag-dropdown"
            class="tag-dropdown"
            role="listbox"
            aria-multiselectable="true"
            hidden
          >
            <div class="flex items-center justify-between px-2.5 py-1.5 border-b border-rim-soft text-xs text-muted">
              <span id="tag-filter-by-tag" class="text-sm px-1 py-0.5">Filter by tag</span>
              <button type="button" id="tag-clear" class="text-sm text-muted px-1 py-0.5 cursor-pointer hover:text-ink">Clear</button>
            </div>
            <ul class="list-none m-0 p-1 overflow-y-auto">
              {tags.map((tag) => (
                <li>
                  <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-pointer text-base text-ink hover:bg-surface-alt">
                    <input type="checkbox" name="tag" value={tag} autocomplete="off" />
                    {tag}
                  </label>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}
    </div>
  </div>
</header>

<style>
  /* Only complex positioning remains — all layout/spacing now uses Tailwind */
  .tag-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 200px;
    background: var(--color-background-primary);
    border: 1.5px solid var(--color-border-secondary);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    z-index: 50;
  }
</style>

<script>
  function getSelectedTags(): string[] {
    return Array.from(
      document.querySelectorAll<HTMLInputElement>('input[name="tag"]:checked')
    ).map(cb => cb.value);
  }

  function updateBadge() {
    const badge   = document.getElementById('tag-badge') as HTMLElement | null;
    const trigger = document.getElementById('tag-trigger') as HTMLButtonElement | null;
    const count   = getSelectedTags().length;
    if (!badge) return;
    badge.hidden      = count === 0;
    badge.textContent = String(count);
    trigger?.setAttribute('aria-label', count > 0 ? `Tags — ${count} selected` : 'Tags');
  }

  function dispatchFilter() {
    const input = document.getElementById('search-input') as HTMLInputElement | null;
    document.dispatchEvent(new CustomEvent('hex-filter', {
      detail: {
        searchTerm: input?.value.trim().toLowerCase() ?? '',
        tags: getSelectedTags(),
      }
    }));
  }

function openDropdown() {
  const dd      = document.getElementById('tag-dropdown') as HTMLElement | null;
  const trigger = document.getElementById('tag-trigger') as HTMLElement | null;
  if (!dd) return;

  // Calculate available space below the trigger
  const rect      = trigger!.getBoundingClientRect();
  const available = window.innerHeight - rect.bottom - 16; // 16px breathing room

  // Apply dynamic max-height to the scrollable list, not the whole dropdown
  const list = dd.querySelector<HTMLElement>('.tag-dropdown__list');
  if (list) list.style.maxHeight = `${Math.max(available - 40, 80)}px`; // 40px for header row, 80px minimum

  dd.hidden = false;
  trigger?.setAttribute('aria-expanded', 'true');
}
  function closeDropdown() {
    const dd      = document.getElementById('tag-dropdown') as HTMLElement | null;
    const trigger = document.getElementById('tag-trigger') as HTMLElement | null;
    if (!dd) return;
    dd.hidden = true;
    trigger?.setAttribute('aria-expanded', 'false');
  }

  function toggleDropdown() {
    const dd = document.getElementById('tag-dropdown') as HTMLElement | null;
    dd?.hidden ? openDropdown() : closeDropdown();
  }

  function onHexHover(e: Event) {
    const { slug } = (e as CustomEvent).detail;
    const caption = document.getElementById('header-caption') as HTMLElement | null;
    if (caption) caption.textContent = slug ?? '';
  }

  function init() {
    const input   = document.getElementById('search-input') as HTMLInputElement | null;
    const trigger = document.getElementById('tag-trigger') as HTMLElement | null;
    const clear   = document.getElementById('tag-clear') as HTMLElement | null;

    // Reset state on navigation
    if (input) input.value = '';
    document.querySelectorAll<HTMLInputElement>('input[name="tag"]')
      .forEach(cb => { cb.checked = false; });
    updateBadge();
    closeDropdown();

    // Search input
    let debounce: ReturnType<typeof setTimeout>;
    input?.addEventListener('input', () => {
      clearTimeout(debounce);
      debounce = setTimeout(dispatchFilter, 200);
    });

    // Trigger toggle
    trigger?.addEventListener('click', toggleDropdown);

    // Checkboxes
    document.querySelectorAll<HTMLInputElement>('input[name="tag"]')
      .forEach(cb => {
        cb.addEventListener('change', () => {
          updateBadge();
          dispatchFilter();
        });
      });

    // Clear button
    clear?.addEventListener('click', () => {
      document.querySelectorAll<HTMLInputElement>('input[name="tag"]')
        .forEach(cb => { cb.checked = false; });
      updateBadge();
      dispatchFilter();
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      const wrap = document.querySelector('.tag-dropdown-wrap');
      if (wrap && !wrap.contains(e.target as Node)) closeDropdown();
    });

    // Close on Escape / focus search on "/"
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDropdown();
      if (e.key === '/' && document.activeElement !== input) {
        e.preventDefault();
        input?.focus();
      }
    });

    // Hover caption — managed inside init to handle navigation correctly
    document.removeEventListener('hex-hover', onHexHover);
    document.addEventListener('hex-hover', onHexHover);
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
