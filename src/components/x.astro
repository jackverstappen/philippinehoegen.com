---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import HexGrid from "../components/HexGrid.astro";

const {
  collection  = [],
  ...rest
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const mediaImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/works/**/*.{jpg,jpeg,png,webp,avif,gif}'
);

const tiles = await Promise.all(collection.map(async (p) => {
  let src = "";
  if (p.data.cover) {
    const filename = p.data.cover.replace(/^\.\//, '');
    const loader = mediaImages[`/src/content/works/${p.id}/${filename}`];
    if (loader) {
      const mod = await loader();
      const optimized = await getImage({ src: mod.default, width: 200 });
      src = optimized.src;
    }
  }
  return {
    id: `${p.id}`,
    href: `${base}/works/${p.id}`,
    src,
    alt: p.data.title ?? "",
    title: p.data.title ?? "",
    tags: p.data.tags,
  };
}));
---


<HexGrid tiles={tiles} {...rest} />

<style>
    .hex-grid {
        margin-inline: 4px;
        margin-block: 8px;
    }

    @media screen and (min-width: 44em) {
        .hex-grid {
            margin-inline: 16px;
        }
    }
</style>
