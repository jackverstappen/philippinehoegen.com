---
/**
 * Gallery.astro
 *
 * A thumbnail grid that opens images in an accessible modal lightbox.
 * Keyboard: ← → navigate, Home/End jump to ends, Esc closes.
 * Touch: swipe left/right to navigate.
 *
 * Props:
 *   images  — array of { src: ImageMetadata, alt: string, caption?: string, credit?: string }
 *   label   — aria-label for the dialog (default: "Image gallery")
 *   columns — thumbnail grid columns: 2 | 3 | 4 (default: 3)
 *
 * Usage:
 *   <Gallery images={entry.data.images} columns={3} label="Project photos" />
 */
import { Image } from 'astro:assets';

const {
  images,
  label   = 'Image gallery',
  columns = 3,
} = Astro.props;
---

<div data-gallery>

    <!---
          <Image
            src={img.src}
            alt={img.alt}
            widths={[280, 560]}
            sizes="(max-width: 600px) 50vw, 280px"
            class="gallery-thumb__img"
            loading={i < columns ? 'eager' : 'lazy'}
          />
     -->

  <!-- Thumbnail grid -->
  <ul class="gallery-grid" style={`--cols: ${columns};`} aria-label={label}>
    {images.map((img, i) => (
      <li>
        <button
          class="gallery-thumb"
          data-gallery-thumb
          aria-label={`Open image ${i + 1}: ${img.alt}`}
          type="button"
        >
        <img
          class="image fade-in gallery-thumb__img"
          src={img.src}
          alt={img.alt}
        />
          <span class="gallery-thumb__overlay" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M8 3H3v5M17 8V3h-5M12 17h5v-5M3 12v5h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
      </li>
    ))}
  </ul>

  <!-- Modal backdrop -->
  <div data-gallery-backdrop class="gallery-backdrop" hidden aria-hidden="true">
    <div
      data-gallery-modal
      class="gallery-modal"
      role="dialog"
      aria-modal="true"
      aria-label={label}
      tabindex="-1"
    >

      <!-- Header -->
      <header class="gallery-modal__header">
        <span data-gallery-title class="gallery-modal__title"></span>
        <div class="gallery-modal__header-end">
          <span data-gallery-counter class="gallery-modal__counter" aria-live="polite"></span>
          <button data-gallery-close class="gallery-modal__close" aria-label="Close gallery" type="button">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </header>

      <!-- 
                     <Image
                inferSize:true 
                src={img.src}
                alt={img.alt}
                widths={[800, 1200, 1600]}
                sizes="(max-width: 900px) 100vw, 860px"
                class="gallery-modal__image"
                loading={i === 0 ? 'eager' : 'lazy'}
              />

                          sizes="auto, (max-width: 30em) 100vw, (max-width: 50em) 50vw, calc(33vw - 100px)"

              -->

      <!-- Stage -->
      <div class="gallery-modal__stage">
        <div data-gallery-track class="gallery-modal__track">
          {images.map((img, i) => (
            <div
              data-gallery-slide
              data-title={img.alt}
              data-caption={img.caption ?? ''}
              class="gallery-modal__slide"
              aria-hidden={i !== 0 ? 'true' : 'false'}
              aria-current={i === 0 ? 'true' : 'false'}
            >
        <img
          class="image fade-in gallery-modal__image"
max-width="80%"
max-height="80%"
          src={img.src}
          alt={img.alt}
        />

            </div>
          ))}
        </div>

        <button data-gallery-prev class="gallery-modal__nav gallery-modal__nav--prev" aria-label="Previous image" type="button">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M11 14L6 9l5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <button data-gallery-next class="gallery-modal__nav gallery-modal__nav--next" aria-label="Next image" type="button">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <!-- Footer -->
      <footer class="gallery-modal__footer">
        <p data-gallery-caption class="gallery-modal__caption" aria-live="polite"></p>
        <div class="gallery-modal__dots" role="tablist" aria-label="Image navigation">
          {images.map((img, i) => (
            <button
              data-gallery-dot
              class="gallery-modal__dot"
              role="tab"
              aria-label={`Image ${i + 1}: ${img.alt}`}
              aria-current={i === 0 ? 'true' : 'false'}
              type="button"
            />
          ))}
        </div>
      </footer>

    </div>
  </div>

</div>

<style>
.gallery-grid {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(var(--cols, 3), minmax(0, 1fr));
  gap: 8px;
}

.gallery-thumb {
  display: block;
  width: 100%;
  padding: 0;
  border: none;
  background: none;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  border-radius: 6px;
  aspect-ratio: 4 / 3;
}

.gallery-thumb__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  transition: transform 0.3s ease;
}

.gallery-thumb:hover .gallery-thumb__img,
.gallery-thumb:focus-visible .gallery-thumb__img {
  transform: scale(1.04);
}

.gallery-thumb__overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0);
  color: #fff;
  opacity: 0;
  transition: opacity 0.2s, background 0.2s;
}

.gallery-thumb:hover .gallery-thumb__overlay,
.gallery-thumb:focus-visible .gallery-thumb__overlay {
  opacity: 1;
  background: rgba(0, 0, 0, 0.3);
}

.gallery-thumb:focus-visible {
  outline: 2px solid var(--color-border-info, #378add);
  outline-offset: 2px;
}

.gallery-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.75);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  animation: backdrop-in 0.18s ease;
}

.gallery-backdrop[hidden] { display: none; }

@keyframes backdrop-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.gallery-modal {
  background: var(--color-background-primary, #fff);
  border-radius: 12px;
  border: 0.5px solid var(--color-border-tertiary, rgba(0,0,0,0.12));
  width: 100%;
  max-width: 860px;
  max-height: calc(100svh - 40px);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  outline: none;
  animation: modal-in 0.2s ease;
}

@keyframes modal-in {
  from { opacity: 0; transform: scale(0.97) translateY(8px); }
  to   { opacity: 1; transform: scale(1)    translateY(0);   }
}

.gallery-modal__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 0.5px solid var(--color-border-tertiary, rgba(0,0,0,0.1));
  flex-shrink: 0;
}

.gallery-modal__title {
  font-size: 14px;
  font-weight: 500;
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 60%;
}

.gallery-modal__header-end {
  display: flex;
  align-items: center;
  gap: 12px;
}

.gallery-modal__counter {
  font-size: 12px;
  color: var(--color-text-secondary);
  font-variant-numeric: tabular-nums;
}

.gallery-modal__close {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: transparent;
  border: 0.5px solid var(--color-border-secondary, rgba(0,0,0,0.2));
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-secondary);
  transition: background 0.15s;
  flex-shrink: 0;
}

.gallery-modal__close:hover { background: var(--color-background-secondary); }

.gallery-modal__close:focus-visible {
  outline: 2px solid var(--color-border-info, #378add);
  outline-offset: 2px;
}

.gallery-modal__stage {
  position: relative;
  flex: 1;
  overflow: hidden;
  background: var(--color-background-tertiary, #f5f5f5);
  min-height: 0;
}

.gallery-modal__track {
  display: flex;
  height: 100%;
  transition: transform 0.28s ease;
  will-change: transform;
}

.gallery-modal__slide {
  min-width: 100%;
  height: 100%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

iddmg {
    object-fit: contain;
    object-position: 50% 50%;
}

.gallery-modal__image {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
  display: block;
}

.gallery-modal__nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: var(--color-background-primary, #fff);
  border: 0.5px solid var(--color-border-secondary, rgba(0,0,0,0.2));
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-primary);
  z-index: 2;
  transition: background 0.15s;
}

.gallery-modal__nav:hover { background: var(--color-background-secondary); }
.gallery-modal__nav--prev { left: 12px; }
.gallery-modal__nav--next { right: 12px; }

.gallery-modal__nav:focus-visible {
  outline: 2px solid var(--color-border-info, #378add);
  outline-offset: 2px;
}

.gallery-modal__footer {
  padding: 12px 16px 14px;
  border-top: 0.5px solid var(--color-border-tertiary, rgba(0,0,0,0.1));
  flex-shrink: 0;
}

.gallery-modal__caption {
  font-size: 13px;
  color: var(--color-text-secondary);
  margin: 0 0 10px;
  min-height: 18px;
}

.gallery-modal__dots { display: flex; gap: 5px; }

.gallery-modal__dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-border-secondary, rgba(0,0,0,0.2));
  border: none;
  padding: 0;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}

.gallery-modal__dot.is-active {
  background: var(--color-text-primary);
  transform: scale(1.4);
}

.gallery-modal__dot:focus-visible {
  outline: 2px solid var(--color-border-info, #378add);
  outline-offset: 3px;
}

@media (max-width: 480px) {
  .gallery-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .gallery-modal__nav { display: none; }
}
</style>

<script>
  import { initGallery } from '../scripts/galleryActions.js';
  document.querySelectorAll('[data-gallery]').forEach(initGallery);
</script>