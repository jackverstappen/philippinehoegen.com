---
/**
 * Gallery.astro
 *
 * Thumbnail grid that opens images in a modal slideshow.
 * Keyboard: ← → navigate, Esc closes.
 * Touch: swipe left/right to navigate.
 *
 * Props:
 *   images  — array of { src: ImageMetadata, alt: string, caption?: string }
 *   label   — aria-label for the dialog (default: "Image gallery")
 *   columns — thumbnail grid columns: 2 | 3 | 4 (default: 3)
 */
import { getImage } from 'astro:assets';

const {
  images,
  label   = 'Image gallery',
  columns = 3,
} = Astro.props;

const processedImages = await Promise.all(
  images.map(async (img) => {
    const thumb = await getImage({ src: img.src, width: 560 });
    const full  = await getImage({ src: img.src, width: 1600 });
    return { ...img, thumbSrc: thumb.src, fullSrc: full.src };
  })
);
---

<div data-gallery>

  <!-- Thumbnail grid -->
  <ul class="gallery-grid" style={`--cols: ${columns};`} aria-label={label}>
    {processedImages.map((img, i) => (
      <li>
        <button
          class="gallery-thumb"
          data-gallery-thumb
          aria-label={`Open image ${i + 1}: ${img.alt}`}
          type="button"
        >
          <img
            class="image fade-in gallery-thumb__img"
            src={img.thumbSrc}
            alt={img.alt}
          />
          <span class="gallery-thumb__overlay" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M8 3H3v5M17 8V3h-5M12 17h5v-5M3 12v5h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
      </li>
    ))}
  </ul>

  <!-- Modal backdrop -->
  <div data-gallery-backdrop class="gallery-backdrop" hidden aria-hidden="true">
    <div
      data-gallery-modal
      class="gallery-modal"
      role="dialog"
      aria-modal="true"
      aria-label={label}
      tabindex="-1"
    >

      <!-- Header -->
      <header class="gallery-modal__header">
        <span data-gallery-title class="gallery-modal__title"></span>
        <div class="gallery-modal__header-end">
          <span data-gallery-counter class="gallery-modal__counter" aria-live="polite"></span>
          <button data-gallery-close class="gallery-modal__close" aria-label="Close gallery" type="button">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </header>

      <!-- Stage -->
      <div class="gallery-modal__stage">
        <div data-gallery-track class="gallery-modal__track">
          {processedImages.map((img, i) => (
            <div
              data-gallery-slide
              data-title={img.alt}
              data-caption={img.caption ?? ''}
              class="gallery-modal__slide"
              aria-hidden={i !== 0 ? 'true' : 'false'}
              aria-current={i === 0 ? 'true' : 'false'}
            >
              <img
                class="image fade-in gallery-modal__image"
                src={img.fullSrc}
                alt={img.alt}
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </div>
          ))}
        </div>

        <button data-gallery-prev class="gallery-modal__nav gallery-modal__nav--prev" aria-label="Previous image" type="button">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M11 14L6 9l5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button data-gallery-next class="gallery-modal__nav gallery-modal__nav--next" aria-label="Next image" type="button">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <!-- Footer -->
      <footer class="gallery-modal__footer">
        <p data-gallery-caption class="gallery-modal__caption" aria-live="polite"></p>
        <div class="gallery-modal__dots" role="tablist" aria-label="Image navigation">
          {processedImages.map((img, i) => (
            <button
              data-gallery-dot
              class="gallery-modal__dot"
              role="tab"
              aria-label={`Image ${i + 1}: ${img.alt}`}
              aria-current={i === 0 ? 'true' : 'false'}
              type="button"
            />
          ))}
        </div>
      </footer>

    </div>
  </div>

</div>

<style>
.gallery-grid {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(var(--cols, 3), minmax(0, 1fr));
  gap: 8px;
}

.gallery-thumb {
  display: block;
  width: 100%;
  padding: 0;
  border: none;
  background: none;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  border-radius: 6px;
  aspect-ratio: 4 / 3;
}

.gallery-thumb__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  transition: transform 0.3s ease;
}

.gallery-thumb:hover .gallery-thumb__img,
.gallery-thumb:focus-visible .gallery-thumb__img {
  transform: scale(1.04);
}

.gallery-thumb__overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0);
  color: #fff;
  opacity: 0;
  transition: opacity 0.2s, background 0.2s;
}

.gallery-thumb:hover .gallery-thumb__overlay,
.gallery-thumb:focus-visible .gallery-thumb__overlay {
  opacity: 1;
  background: rgba(0, 0, 0, 0.3);
}

.gallery-thumb:focus-visible {
  outline: 2px solid var(--color-border-info, #378add);
  outline-offset: 2px;
}

/* ── Modal ── */
.gallery-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.gallery-backdrop[hidden] { display: none; }

.gallery-modal {
  background: var(--color-background-primary, #fff);
  border-radius: 12px;
  width: 100%;
  max-width: 900px;
  height: calc(100svh - 40px);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  outline: none;
}

.gallery-modal__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 0.5px solid rgba(0,0,0,0.1);
  flex-shrink: 0;
}

.gallery-modal__title {
  font-size: 14px;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 60%;
}

.gallery-modal__header-end {
  display: flex;
  align-items: center;
  gap: 12px;
}

.gallery-modal__counter {
  font-size: 12px;
  color: var(--color-text-secondary, #888);
  font-variant-numeric: tabular-nums;
}

.gallery-modal__close {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: transparent;
  border: 0.5px solid rgba(0,0,0,0.2);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
  flex-shrink: 0;
}
.gallery-modal__close:hover { background: rgba(0,0,0,0.06); }

/* Stage: takes all remaining height, clips the sliding track */
.gallery-modal__stage {
  position: relative;
  flex: 1;
  min-height: 0;          /* allow shrink inside flex column */
  overflow: hidden;
  background: #111;
}

/* Track slides horizontally */
.gallery-modal__track {
  display: flex;
  height: 100%;
  transition: transform 0.3s ease;
  will-change: transform;
}

/* Each slide fills the stage exactly */
.gallery-modal__slide {
  min-width: 100%;
  height: 100%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Image fills the slide, letterboxed */
.gallery-modal__image {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  margin-top: 0;
}

.gallery-modal__nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: rgba(255,255,255,0.9);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  transition: background 0.15s;
  backdrop-filter: blur(4px);
}
.gallery-modal__nav:hover { background: #fff; }
.gallery-modal__nav--prev { left: 12px; }
.gallery-modal__nav--next { right: 12px; }

.gallery-modal__footer {
  padding: 10px 16px 12px;
  border-top: 0.5px solid rgba(0,0,0,0.1);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gallery-modal__caption {
  font-size: 13px;
  color: var(--color-text-secondary, #888);
  margin: 0;
  min-height: 18px;
}

.gallery-modal__dots { display: flex; gap: 5px; flex-wrap: wrap; }

.gallery-modal__dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: rgba(0,0,0,0.2);
  border: none;
  padding: 0;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.gallery-modal__dot.is-active {
  background: var(--color-text-primary, #000);
  transform: scale(1.4);
}

@media (max-width: 480px) {
  .gallery-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .gallery-modal__nav { display: none; }
}
</style>

<script>
  import { initGallery } from '../scripts/galleryActions.js';
  document.querySelectorAll('[data-gallery]').forEach(initGallery);
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('[data-gallery]').forEach(initGallery);
  });
</script>
