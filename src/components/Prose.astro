---
<div class="prose">
  <slot />
</div>

<style>
  /*
   * All rules here use :global() so they reach the rendered
   * Markdoc / Markdown output, which has no scoped attribute.
   */

  .prose :global(p) {
    font-size: 1rem;
    margin-block: 0.75rem;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-size: 1rem;
    font-weight: 700;
    margin-block: 0.75rem 0.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    font-size: 1rem;
    padding-inline-start: 1.25rem;
    margin-block: 0.25rem;
  }

  .prose :global(a) {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
