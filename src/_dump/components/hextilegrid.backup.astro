---
/**
 * HexTileGrid.astro
 *
 * Hexagonal image-tile gallery, faithful to the Observable Plot homepage.
 *
 * ── How the hex shape works ───────────────────────────────────────────────
 * Each tile uses the CSS clip-path polygon straight from the Observable
 * source — no SVG <clipPath> required:
 *
 *   clip-path: polygon(50% 100%, 93.3% 75%, 93.3% 25%, 50% 0%, 6.7% 25%, 6.7% 75%)
 *
 * ── How the 2 px border works ─────────────────────────────────────────────
 * CSS `border` is clipped away by `clip-path`, so the border is achieved by:
 *   1. giving the `<a>` tile a background colour (the border colour)
 *   2. positioning the `<img>` absolutely with `inset: 2px`
 *
 * Because clip-path clips the whole tile element (background included), the
 * 2 px ring of background that peeks around the inset image forms a perfect
 * hex-shaped border — no extra elements needed.
 *
 * ── Positioning ───────────────────────────────────────────────────────────
 * Each `<a>` receives CSS custom properties via inline style:
 *   --x  integer column index
 *   --y  integer row index
 *   --p  parity (0 | 1) — drives the half-row stagger on odd columns
 *   --i  tile index — drives the sequential animation delay
 *
 * The container exposes --col-step, --row-step, --stagger as pixel values.
 * The CSS transform reads them:
 *   transform: translate(
 *     calc(var(--x) * var(--col-step)),
 *     calc(var(--y) * var(--row-step) + var(--p) * var(--stagger))
 *   )
 *
 * ── Props ──────────────────────────────────────────────────────────────────
 *  tiles       { href, src, alt, title? }[]   images to show
 *  cols        number   columns                          default 7
 *  hexSize     number   tile width in px                 default 180
 *  gap         number   gap between tiles in px          default 6
 *  borderColor string   tile border / ring colour        default "white"
 *  animated    boolean  enable the sweep animation       default true
 *  class       string   extra classes on the container
 */

const {
  tiles        = [],
  cols         = 7,
  hexSize      = 180,
  gap          = 1,
  borderWidth  = 2.5,
  magnify      = 1.2,
  borderColor  = "black",
  animated     = true,
  class: className = "",
  ...rest
} = Astro.props;

// ─── Geometry ────────────────────────────────────────────────────────────────
// Pointy-top hexagon inscribed in a W × H rectangle.
// The clip-path polygon uses the 6.7 % / 93.3 % coordinates, which define a
// regular pointy-top hex when H/W = 2/√3 ≈ 1.1547.

const sqrtThree = Math.sqrt(3);
const radius = (hexSize/2) + borderWidth;
const pWidth = sqrtThree * radius ;
const pHeight = 2 * radius;
const hSpace = pWidth+gap  -.5;
const vSpace = (pHeight + 2*gap)  * .75;
const borderScale = 1 - (borderWidth / pHeight);

/*
 “odd-r” horizontal layout shoves odd rows right
“even-r” horizontal layout shoves even rows right
 “odd-q”   vertical layout shoves odd columns down
“even-q”   vertical layout shoves even columns down
*/

const ggap = 0;
//const W = hexSize;                           // tile width
//const H = hexSize * (2 / Math.sqrt(3));      // tile height for a regular hex
const W = pWidth*1.15;                           // tile width
const H = pHeight ;      // tile height for a regular hex

const colStep = hSpace/2;
const rowStep = vSpace;

// Odd columns are shifted down by half a row (stagger)
const stagger = hSpace / 2;

// ─── Grid layout ─────────────────────────────────────────────────────────────
const grid = tiles.map((tile, i) => {
  const col    = i % cols;
  const row    = Math.floor(i / cols);
  const parity = row % 2;          // 1 on odd columns → shifted down
  const delay = (1.5*Math.random()).toFixed(3);
  return { ...tile, col, row, parity, idx: i,delay };
});

// ─── Container dimensions ────────────────────────────────────────────────────
const totalCols  = Math.min(tiles.length, cols);
const totalRows  = Math.ceil(tiles.length / cols);
const containerW = totalCols * hSpace + stagger + .145*stagger*2;
const containerH = (hSpace * (totalRows-1) ) + H - .145*stagger;



---



<div
  class:list={["hex-grid", { "hex-grid--animated": animated }, className]}
  style={`
    --tile-w: ${W.toFixed(2)}px;
    --tile-h: ${H.toFixed(2)}px;
    --col-step: ${colStep.toFixed(2)}px;
    --row-step: ${rowStep.toFixed(2)}px;
    --vspace: ${vSpace.toFixed(2)}px;
    --hspace: ${hSpace.toFixed(2)}px;
    --stagger: ${stagger.toFixed(2)}px;
    --border-width: ${borderWidth.toFixed(2)}px;
    --border-scale: ${borderScale.toFixed(4)};
    --border-color: ${borderColor};
    --magnify: ${magnify};
    --col-width: ${pWidth.toFixed(2)}px;
    width: ${containerW.toFixed(1)}px;
    height: ${containerH.toFixed(1)}px;

`}
  {...rest}
>
  {grid.map(({ href, src, alt, title, col, row, parity, idx, delay }) => (
    <a
      class="hex-tile"
      href={href}
      title={title ?? alt}
      style={`--x:${col};--y:${row};--p:${parity};--i:${idx};--delay:${delay}`}
    >
      <img
        src={src}
        alt={alt}
        width={W}
        height={H}
        loading="lazy"
        decoding="async"
      />
    </a>
  ))}
</div>

<style>
  /* ── Container ──────────────────────────────────────────────────────────── */
  .hex-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
    /* width / height injected inline by Astro */
  }

  /* ── Tile shell ─────────────────────────────────────────────────────────── */
  .hex-tile {
    position: absolute;
    display: block;
    width:  var(--tile-w);
    height: var(--tile-h);

    /*
     * ── THE hex clip-path (straight from Observable Plot) ─────────────────
     * Pointy-top hexagon: vertex at top-centre and bottom-centre.
     * The 6.7 % / 93.3 % values are cos(30°) offsets that produce a
     * regular hexagon when the aspect ratio is W:H = √3:2.
     */

    clip-path: url("#svgHexagon2");


    background: var(--border-color, black);
    --tx: rotateX(0deg) rotateY(0deg) translate(
      calc((var(--x)* var(--hspace)) +  var(--p,0)*var(--stagger)),
      calc(var(--y) * var(--vspace) + .145*var(--stagger))
    );
    transform: var(--tx);
    /*
    animation: hex-drop .35s cubic-bezier(.215, .61, .355, 1) var(2) backwards;
    transition: transform .25s ease-out;
    */
    filter: grayscale(1) blur(1.2px); 
    outline: none;
    text-decoration: none;

  }

  /* ── Image — inset 2 px to expose the border ring ──────────────────────── */
  .hex-tile img {
    position: absolute;
    inset: var(--border-width);
    width:  calc(100% - 2*var(--border-width));
    height: calc(100% - 2*var(--border-width));
    object-fit: cover;
    object-position: center;
    filter: saturate(0) blur(1.2px);
    clip-path: url("#svgHexagon2");
    display: block;
  }

  
   .hex-tile img:hover {
    filter: blur(0px);
    transform: scale(1);
   }
   

  /* ── Hover / focus ──────────────────────────────────────────────────────── */
  .hex-tile:hover,
  .hex-tile:focus-visible {
    /*
    transform: translate(
      calc(var(--x) * var(--col-step)),
      calc(var(--y) * var(--row-step) + var(--p, 0) * var(--stagger))
    ) scale(1.07);
     */
    transform: var(--tx) scale(var(--magnify)) ;
 /*   animation: transform 0.5s ease-out;*/
      animation: transform 0.5s ease-in-out;
  /* Ensures smooth 3D rendering */
  backface-visibility: hidden;
  perspective: 1000px;



    filter: brightness(1.1) saturate(0.15);
    z-index: 10;
  }

  /* ── Sequential sweep animation ─────────────────────────────────────────
   *
   *  Each tile has a 60 s cycle (slow and calm, matching Observable's feel).
   *  animation-delay: calc(var(--i) * -1s) seeds every tile at a unique
   *  offset so the grid is already alive on first paint — no cold-start pop.
   *  The bloom peaks at 50 % of the cycle.
   */
  @keyframes hex-bloom {
      0% { filter: brightness(0.85) saturate(0.8);  opacity: 0.75; }
     45% { filter: brightness(0.85) saturate(0.8);  opacity: 0.75; }
     50% { filter: brightness(1.15) saturate(1.25); opacity: 1;    }
     55% { filter: brightness(0.85) saturate(0.8);  opacity: 0.75; }
    100% { filter: brightness(0.85) saturate(0.8);  opacity: 0.75; }
  }

  @keyframes hex-drop {
        0% {transform: var(--tx) translateY(-100px) translateZ(400px)}
        to {transform: var(--tx)}
    }

    @keyframes wiggle3d {
  0% { transform: translate3d(0, 0, 0) rotateY(0deg); }
  25% { transform: translate3d(-5px, 0, 10px) rotateY(-10deg); }
  50% { transform: translate3d(5px, 0, 10px) rotateY(10deg); }
  75% { transform: translate3d(-5px, 0, 10px) rotateY(-10deg); }
  100% { transform: translate3d(0, 0, 0) rotateY(0deg); }
}

  .hex-grid--animated .hex-tile.older {
    animation: hex-drop 3s cubic-bezier(.215, .61, .355, 1) var(2) backwards ;
  }

  .hex-grid--animated .hex-tile-old {
    opacity: 0.75;
    animation: hex-bloom 6s ease-in-out calc(var(--i, 0) * -1s) infinite;
  }

  /* Hover wins over the running animation */
  .hex-grid--animated .hex-tile:hover,
  .hex-grid--animated .hex-tile:focus-visible {
    animation: none;
    filter: brightness(1.1) saturate(1.15);
    opacity: 1;
  }

  /* ── Reduced motion ─────────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hex-tile,
    .hex-grid--animated .hex-tile {
      animation: none;
      transition: none;
      opacity: 1;
    }
    .hex-tile:hover,
    .hex-tile:focus-visible {
      filter: brightness(1.08);
    }
  }
</style>
<script>
const grid =  document.querySelector('.gallery-grid') as HTMLElement;

function syncCols() {
  const computed = getComputedStyle(grid);
  const cols = computed
    .getPropertyValue('grid-template-columns')
    .trim()
    .split(' ')
    .length;

  grid.style.setProperty('--cols', `${cols}`);
  console.log("grid",cols);

  (grid.querySelectorAll('.hex-tile') as NodeListOf<HTMLElement>).forEach((el, i) => {
      console.log("cel",i,cols,el);

      const item = /** @type {HTMLElement} */ (el);

    item.style.setProperty('--i', `${i}`);
    item.style.setProperty('--col', `${i % cols}`);
    item.style.setProperty('--row', `${Math.floor(i / cols)}`);
  });
}

console.log("init?",grid)
const ro = new ResizeObserver(syncCols);
ro.observe(grid);
syncCols(); // run once on init

</script>